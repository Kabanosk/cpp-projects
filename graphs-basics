#include <iostream>
#include <vector>

using namespace std;

auto addEdge(vector<vector<int>> adj, int v, int u) {
    adj[v].push_back(u);
    adj[u].push_back(v);
    return adj;
}

void printGraph(vector<vector<int>> adj, int V) {
    for (unsigned int i = 0; i < V; i++) {
        cout << "\n Adjacency list of vertex " << i << endl << i;

        for (unsigned int j = 0; j < adj[i].size(); j++)
        {
            cout << " > " << adj[i][j];
        }
    }
}


int main()
{
    int V = 5;
    vector<vector<int>> adj(V);

    adj = addEdge(adj, 0, 1);
    adj = addEdge(adj, 0, 4);
    adj = addEdge(adj, 1, 2);
    adj = addEdge(adj, 1, 3);
    adj = addEdge(adj, 1, 4);
    adj = addEdge(adj, 2, 3);
    adj = addEdge(adj, 3, 4);
    printGraph(adj, V);

    return 0;
}
